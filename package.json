{
  "name": "hexagonal",
  "version": "1.0.0",
  "description": "Arquitetura Hexagonal",
  "main": "build/shared/infra/http/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/shared/infra/http/server.ts --legacy-watch",
    "lint": "eslint .",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "npm run build && node -r tsconfig-paths/register build/shared/infra/http/server.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/shared/infra/db/data-source.ts",
    "tests": "jest",
    "merge": "node merge_tool.js -p src/ -o context.txt "
  },
  "keywords": [],
  "author": "Cleverson Matias",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  }
}
